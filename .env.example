# ─── SERVER ───────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── SUPABASE POSTGRES ────────────────────────────────────
# Local dev: use pooler host from Supabase → Settings → Database → Connection pooling
# Render:    MUST use pooler (aws-*-*.pooler.supabase.com), NOT db.*.supabase.co
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASS=your_supabase_db_password
DB_SSL=true

# Optional: paste Supabase "Transaction pooler" URI instead of DB_* vars above
# DATABASE_URL=postgresql://postgres.your_ref:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Set true once when deploying schema changes (shopLogo, view_logs indexes, etc.)
# Leave false in production after tables are up to date
DB_SYNC_ALTER=true

# ─── JWT (legacy routes; auth is Firebase) ───────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── CLOUDINARY (image uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── FIREBASE ADMIN SDK ───────────────────────────────────
FIREBASE_PROJECT_ID=cavsulit-v2
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@cavsulit-v2.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
